# -----------------------------------------------------------------------
# amuse_nbody7/src/Makefile
# -----------------------------------------------------------------------
# Build NBODY7 as a static library (libnbody7.a) that the AMUSE
# worker (nbody7_worker) links against.
#
# Strategy
# --------
# The upstream NBODY7 build is a two-stage pipeline owned by
# updated-nbody7/GPU2/Makefile:
#
#   Stage 1 (GPU2/Makefile, cpu target):
#     - Compiles the C++ sources in GPU2/lib/ (gpunb.cpp, gpupot.cpp,
#       cnbint6.cpp, wtime.cpp, cxvpred.cpp) and GPU2/irrlib/
#       (gpuirr.cpp) with $(CXX).
#     - Compiles the OpenMP-annotated Fortran kept directly under GPU2/
#       (intgrt.omp.f, start.f) plus ~22 other GPU2-local .f overrides
#       of Block/ routines (gpucor.f, nbintp.f, cmfirr.f, etc.) with
#       $(FC) -fopenmp.
#     - Renames the CPU variants (gpunb.cpu.o -> gpunb.o,
#       gpuirr.cpu.o -> gpuirr.o, cnbint6.o -> cnbint.o) and copies
#       every .o into GPU2/Build/.
#
#   Stage 2 (Makefile_cpu.build, cpu target, auto-invoked by Stage 1):
#     - Compiles the remaining ~180 Fortran sources under Block/ (found
#       via VPATH) and links a (throwaway) `nbody6' executable in
#       Build/.
#
# Rather than re-implement either stage, we invoke the upstream `cpu'
# target directly and then archive GPU2/Build/*.o into libnbody7.a,
# excluding nbody6_main.o (PROGRAM NBODY6_MAIN) so the AMUSE worker
# can supply its own main via nbody7_worker.f90.
#
# Tool variables (FC, MPIFC, CXX, AR, RANLIB, CPU_COUNT) come from
# support/config.mk which is generated by support/configure.
# -----------------------------------------------------------------------

# Skip including config.mk for pure cleanup targets so that `make clean'
# works even before `configure' has been run.
ifneq (,$(filter-out clean distclean, $(MAKECMDGOALS)))
include ../support/config.mk
endif


# VERSION is the upstream NBODY7 commit hash that the outer Makefile
# downloads / extracts into src/. The outer Makefile passes its own
# VERSION through on the sub-make command line (`make -C src VERSION=...`),
# which overrides the assignment below. We use ?= so the value stays
# settable: a command-line variable always wins over an in-Makefile ?=
# assignment, while standalone invocations of this Makefile (e.g. for
# clean / distclean from inside src/) still get a working default.
# Keep the default below in sync with the outer Makefile when bumping.
VERSION   ?= 6a5a64af2e9bbef8965c2ccaa6f132fcfa5edf45
SRCTREE   := updated-nbody7-$(VERSION)
GPU2DIR   := $(SRCTREE)/GPU2

# VARIANT selects which upstream NBODY7 build is archived into the
# AMUSE worker codelib:
#   cpu          - portable scalar (default; v0)
#   sse          - x86 SSE intrinsics
#   avx          - x86 AVX intrinsics + AVX-mode gpuirr.s assembly
#   gpu          - CUDA (requires nvcc + CUDA runtime)
# Each variant emits into its own Build_$(VARIANT)/ inside GPU2/ and
# produces libnbody7_$(VARIANT).a so multiple variants can coexist in
# one source tree.
VARIANT         ?= cpu
UPSTREAM_TARGET := $(VARIANT)-objects
BUILDDIR        := $(GPU2DIR)/Build_$(VARIANT)
CODELIB         := libnbody7_$(VARIANT).a


# NBODY7 build options passed down to GPU2/Makefile:
#   ksblock=on        - Block/ Fortran variant (the Step 2 AMUSE-hook
#                       refactor lives under Block/, not Ncode/).
#   chainmode=archain - ARCHAIN post-Newtonian chain regularization,
#                       the principal reason NBODY7 is used over NBODY6++.
# These match the upstream defaults but are passed explicitly for safety
# in case a developer edits the GPU2/Makefile header values.
NBODY_OPTS := ksblock=on chainmode=archain

# AVX variant: the upstream gpuirr.o rule is gated on `avx=enable` (see
# GPU2/Makefile lines 138-152). Without this flag, gpuirr.o would be
# built from the SSE source even under the avx-objects target, defeating
# the AVX selection.
ifeq ($(VARIANT),avx)
NBODY_OPTS += avx=enable
endif

# GPU variant: forward AMUSE-configure's detected CUDA toolkit path
# (CUDA_TK, populated by AMUSE_CUDA() in support/configure.ac) into
# GPU2/Makefile as CUDA_PATH so nvcc, cuda_runtime headers, and libcudart
# are all sourced from the same toolkit AMUSE detected. Without this,
# GPU2/Makefile falls back to its own $(CONDA_PREFIX)-or-/usr/local/cuda
# default, which can disagree with what the AMUSE worker links against.
#
# SDK_PATH points at an NVIDIA cuda-samples checkout (public repo:
# https://github.com/NVIDIA/cuda-samples). With -DWITH_CUDA5 set (which
# GPU2/Makefile always passes), lib/gpunb.velocity.cu and lib/gpupot.gpu.cu
# `#include <helper_cuda.h>` from cuda-samples' Common/. The conda CUDA
# toolkit does NOT ship those samples -- clone the repo and pass
# SDK_PATH=/path/to/cuda-samples on the outer make command line (or
# export it in the environment). Forwarded only when non-empty so cpu/
# sse/avx builds remain unaffected.
ifeq ($(VARIANT),gpu)
ifneq ($(CUDA_TK),)
NBODY_OPTS += CUDA_PATH=$(CUDA_TK)
endif
ifneq ($(SDK_PATH),)
NBODY_OPTS += SDK_PATH=$(SDK_PATH)
endif
endif


.PHONY: all build-objects clean distclean

all: $(CODELIB)


# -----------------------------------------------------------------------
# Invoke the upstream two-stage build (GPU2/Makefile $(VARIANT)-objects
# -> Stage 1 C++ + GPU2-local Fortran, then recurses into the per-variant
# Build_$(VARIANT)/ with Makefile_cpu.build for Stage 2 Block/ Fortran).
#
# FC is overridden to MPIFC so the object code is ABI-compatible with
# the worker (which is built with MPIFC). CXX uses whatever configure
# detected (plain g++/clang++ is fine for cpu/sse/avx; gpu also needs
# NVCC and CUDA_PATH, which configure provides for the gpu variant).
#
# BUILD=Build_$(VARIANT) tells GPU2/Makefile to deposit Stage-1 .o files
# and run Stage-2 inside the per-variant subdirectory, so cpu/sse/avx/gpu
# can coexist in one source tree without colliding on Build/.
#
# Stage-1 contamination guard: GPU2/Makefile builds Stage-1 .o files in
# the GPU2/ working directory itself, and its `cp -f *.o ./$(BUILD)/'
# recipe sweeps every .o sitting there into Build_$(VARIANT)/. If a
# previous variant left objects behind (e.g. gpunb.cpu.o, gpuirr.cpu.o
# from an earlier `make install-amuse-nbody7-cpu'), they ride along.
# Wipe those stage-1 leftovers before invoking the upstream make so each
# variant starts from a clean GPU2/ working directory. The per-variant
# Build_$(VARIANT)/ subdirectory is preserved (Stage-2 owns it).
# -----------------------------------------------------------------------
build-objects:
	rm -f $(GPU2DIR)/*.o $(GPU2DIR)/*.s
	$(MAKE) -C $(GPU2DIR) $(UPSTREAM_TARGET) \
	    -j $(CPU_COUNT) \
	    BUILD=Build_$(VARIANT) \
	    FC="$(MPIFC)" \
	    CXX="$(CXX)" \
	    $(NBODY_OPTS)


# -----------------------------------------------------------------------
# Archive the built objects into libnbody7.a.
#
# The $(wildcard ...) expands when this recipe runs (after
# build-objects has populated $(BUILDDIR) via Stage 1 copy + Stage 2
# compilation), so it captures every .o that was produced.
#
# Filtering rules:
#
#   * nbody6_main.o is the standalone PROGRAM and must not appear in a
#     library linked against a worker main.
#
#   * Variant-tagged duplicates (gpunb.<v>.o, gpupot.<v>.o, gpuirr.cpu.o,
#     cnbint6.o) export the SAME Fortran-callable symbols as the bare
#     canonical names (gpunb.o, gpupot.o, gpuirr.o, cnbint.o) that the
#     upstream recipes copy into place. If both end up in the archive,
#     the linker pulls in whichever appears first alphabetically -- and
#     `gpunb.cpu.o' < `gpunb.o' (lex order on `.cpu' vs `.o'), so the cpu
#     stub silently wins regardless of variant. Same for gpuirr.cpu.o
#     vs gpuirr.o, which is how an `avx'-built archive ended up calling
#     the CPU gpuirr_open_ at runtime ("Opening GPUIRR lib. CPU ver."
#     in an AVX worker). Strip every variant-tagged object so only the
#     canonical-named copy that matches $(VARIANT) survives.
# -----------------------------------------------------------------------
EXCLUDED_OBJS := \
    %/nbody6_main.o \
    %/gpunb.cpu.o %/gpunb.sse.o %/gpunb.avx.o %/gpunb.gpu.o %/gpunb.metal.o \
    %/gpupot.cpu.o %/gpupot.sse.o %/gpupot.avx.o %/gpupot.gpu.o %/gpupot.metal.o \
    %/gpuirr.cpu.o \
    %/cnbint6.o

$(CODELIB): build-objects
	rm -f $@
	$(AR) -ruv $@ \
	    $(filter-out $(EXCLUDED_OBJS), $(wildcard $(BUILDDIR)/*.o))
	$(RANLIB) $@


clean:
	-$(MAKE) -C $(GPU2DIR) clean
	rm -rf $(BUILDDIR)
	rm -f $(CODELIB) *.o *.mod

# distclean also drops the synced/extracted upstream tree; the outer
# Makefile's sync-src (or tarball rule) will recreate it on the next
# build.
distclean: clean
	rm -rf $(SRCTREE)
